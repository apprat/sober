{
  "name": "sober",
  "version": "0.0.3",
  "description": "Material You design style web component UI library",
  "type": "module",
  "scripts": {
    "dev": "node rollup/dev.js",
    "build": "npx tsc && npx rollup --config rollup/rollup.config.js"
  },
  "keywords": [
    "material you",
    "material design",
    "material design3",
    "web ui-library",
    "web components",
    "framework",
    "web",
    "ui-library",
    "tools"
  ],
  "exports": {
    ".": "./dist/main.js",
    "./button": "./dist/button.js",
    "./checkbox": "./dist/checkbox.js",
    "./dialog": "./dist/dialog.js",
    "./floating-action-button": "./dist/floating-action-button.js",
    "./icon-button": "./dist/icon-button.js",
    "./icon": "./dist/icon.js",
    "./label": "./dist/label.js",
    "./layer": "./dist/layer.js",
    "./radio-button": "./dist/radio-button.js",
    "./scrollbar": "./dist/scrollbar.js",
    "./segmented-button-item": "./dist/segmented-button-item.js",
    "./segmented-button": "./dist/segmented-button.js",
    "./slider": "./dist/slider.js",
    "./snackbar": "./dist/snackbar.js",
    "./switch": "./dist/switch.js",
    "./tab-item": "./dist/tab-item.js",
    "./tab": "./dist/tab.js",
    "./table": "./dist/table.js",
    "./tbody": "./dist/tbody.js",
    "./thead": "./dist/thead.js",
    "./tr": "./dist/tr.js",
    "./th": "./dist/th.js",
    "./td": "./dist/td.js",
    "./tooltip": "./dist/tooltip.js",
    "./top-app-bar": "./dist/top-app-bar.js"
  },
  "author": "apprat",
  "repository": "apprat/sober",
  "license": "MIT",
  "main": "./dist/main.js",
  "devDependencies": {
    "typescript": "latest",
    "@rollup/plugin-node-resolve": "^15.0.2",
    "rollup": "^3.20.2",
    "rollup-plugin-uglify": "^6.0.4"
  }
}