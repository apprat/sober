{
  "name": "sober",
  "version": "0.0.31",
  "description": "Material You design style web component UI library",
  "type": "module",
  "scripts": {
    "dev": "node rollup/dev.js",
    "build": "npx tsc && npx rollup --config rollup/rollup.config.js"
  },
  "keywords": [
    "material you",
    "material design",
    "material design3",
    "web ui-library",
    "web components",
    "framework",
    "web",
    "ui-library",
    "tools"
  ],
  "exports": {
    ".": "./dist/main.js",
    "./theme/*": "./theme/*",
    "./*": "./dist/*.js"
  },
  "author": "apprat",
  "repository": "apprat/sober",
  "license": "MIT",
  "main": "./dist/main.js",
  "devDependencies": {
    "typescript": "latest",
    "@rollup/plugin-node-resolve": "^15.0.2",
    "rollup": "^3.20.2",
    "rollup-plugin-uglify": "^6.0.4"
  }
}